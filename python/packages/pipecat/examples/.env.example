# Deepslate API credentials (required)
# Sign up at https://deepslate.eu to obtain these.
DEEPSLATE_VENDOR_ID=
DEEPSLATE_ORGANIZATION_ID=
DEEPSLATE_API_KEY=

# Daily.co transport (required for simple_bot.py)
# Create a room at https://dashboard.daily.co and paste its URL here.
DAILY_API_KEY=
DAILY_ROOM_URL=https://your-domain.daily.co/your-room-name

# ElevenLabs TTS (optional — omit to disable server-side TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_turbo_v2