{
  "name": "@deepslate-labs/proto",
  "version": "0.1.0",
  "description": "Generated TypeScript protobuf bindings for the Deepslate realtime API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate": "buf generate ../../../proto --template ../../buf.gen.yaml",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist src/gen"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.3"
  }
}